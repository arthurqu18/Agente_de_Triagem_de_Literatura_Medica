# ---------------------------------------------------------------------------
# Copie este arquivo para .env (na raiz do projeto) e ajuste se precisar.
#   Windows PowerShell:  Copy-Item .env.example .env
#   WSL / Linux / macOS: cp .env.example .env
# Os valores abaixo já são os padrões usados no código; só descomente o que
# quiser mudar.
# ---------------------------------------------------------------------------

# Modelo carregado no Ollama. Precisa ter sido baixado com `ollama pull`.
# OLLAMA_MODEL=llama3.1

# Endereço do servidor Ollama.
#  - Windows nativo ............: http://localhost:11434
#  - WSL2 com Ollama no Windows : http://localhost:11434 (funciona na maioria
#    dos casos com espelhamento de rede). Se NÃO conectar, use o IP do Windows,
#    por ex.: http://172.20.0.1:11434  (veja o README, seção WSL).
# OLLAMA_BASE_URL=http://localhost:11434

# Modelo de embeddings. TEM que ser o mesmo em feed_db.py e no pipeline.
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Quantos artigos recuperar por pergunta. AUMENTE este número se as respostas
# estiverem pobres (ex.: 12, 16). Padrão: 8.
# RETRIEVER_K=8

# Janela de contexto do Ollama, em tokens. É o parâmetro que faz o modelo
# "enxergar" todos os artigos recuperados em vez de só 2-3. Se aumentar muito o
# RETRIEVER_K, aumente aqui também (ex.: 16384). Padrão: 8192.
# OLLAMA_NUM_CTX=8192

# Máximo de tokens gerados no relatório final. Padrão: 1024.
# OLLAMA_NUM_PREDICT=1024

# Caracteres de cada artigo enviados ao modelo. Padrão: 1600.
# MAX_CHARS_POR_ARTIGO=1600

# Quantidade de artigos indexados por feed_db.py (máx. 1000 no pqa_labeled).
# TAMANHO_AMOSTRA=1000
